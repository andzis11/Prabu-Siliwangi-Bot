# Meteora DLMM Service Environment Variables
# Copy this file to .env and fill in your values

# RPC Configuration
RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key_here  # Optional: for Helius RPC

# Wallet Private Keys (stored in base58 format)
# Format: WALLET_1=your_private_key_here
# Never commit this file to version control!

WALLET_1=your_private_key_in_base58_format_here
# WALLET_2=another_private_key_here
# WALLET_3=yet_another_private_key_here

# Service Configuration
DEBUG_METEORA=0  # Set to 1 for verbose logging
MIN_SOL_AMOUNT=0.001  # Minimum SOL for transactions
FEE_BUFFER=0.08  # SOL buffer for transaction fees

# Telegram Bot (for reference - not used directly in this package)
# TELEGRAM_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Meteora API Configuration
METRORA_API_URL=https://api.meteora.ag
METRORA_PNL_API=https://dlmm.datapi.meteora.ag/positions

# Note:
# 1. Always keep your private keys secure
# 2. Never share your .env file
# 3. Use different wallets for different purposes
# 4. Maintain sufficient SOL balance for transaction fees
# 5. Recommended fee buffer: 0.08 SOL

# How to get your private key in base58 format:
# From a Solana wallet (like Phantom), export private key as base58
# or use: bs58.encode(your_uint8array_private_key)

# Example of a real private key (64 bytes encoded in base58):
# WALLET_1=5MaiiCavjCmn9Hs1o3eznqDEhRwxo7pXiAYez7eQUtGt8TpQ
# (This is just an example, not a real private key)
