{
  "name": "@prabu/pnl-renderer",
  "private": true,
  "version": "1.0.0",
  "description": "Complete PnL card rendering package with canvas support, multiple themes, and currency conversion",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write src/",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "example:basic": "ts-node examples/basic.ts",
    "example:themes": "ts-node examples/all-themes.ts"
  },
  "keywords": [
    "pnl",
    "renderer",
    "canvas",
    "trading",
    "card",
    "visualization",
    "meteora",
    "solana",
    "dlmm"
  ],
  "author": "Andzisone",
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.52",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@meteora-ag/dlmm": "^1.1.0",
    "@solana/web3.js": "^1.95.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prabu-siliwangi/pnl-renderer.git"
  },
  "bugs": {
    "url": "https://github.com/prabu-siliwangi/pnl-renderer/issues"
  },
  "homepage": "https://github.com/prabu-siliwangi/pnl-renderer#readme",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./canvas": {
      "import": "./dist/core/canvasRenderer.js",
      "require": "./dist/core/canvasRenderer.js",
      "types": "./dist/core/canvasRenderer.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "require": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  }
}
