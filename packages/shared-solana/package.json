{
  "name": "@prabu/shared-solana",
  "private": true,
  "version": "1.0.0",
  "description": "Comprehensive Solana utilities for RPC management, wallet operations, token handling, and transaction building",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write src/",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "rpc",
    "wallet",
    "token",
    "transaction",
    "blockchain",
    "utilities",
    "shared",
    "prabu-siliwangi"
  ],
  "author": "Andzisone",
  "license": "MIT",
  "dependencies": {
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.0",
    "axios": "^1.7.9",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prabu-siliwangi/shared-solana.git"
  },
  "bugs": {
    "url": "https://github.com/prabu-siliwangi/shared-solana/issues"
  },
  "homepage": "https://github.com/prabu-siliwangi/shared-solana#readme",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
