{
  "name": "@prabu/ai-router",
  "private": true,
  "version": "1.0.0",
  "description": "Comprehensive AI routing system for Prabu-Siliwangi with OpenRouter integration, task-based routing, and prompt engineering",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write src/",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "openrouter",
    "routing",
    "prompt",
    "engineering",
    "trading",
    "solana",
    "prabu-siliwangi",
    "chatgpt",
    "claude",
    "gemini"
  ],
  "author": "Andzisone",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.95.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prabu-siliwangi/ai-router.git"
  },
  "bugs": {
    "url": "https://github.com/prabu-siliwangi/ai-router/issues"
  },
  "homepage": "https://github.com/prabu-siliwangi/ai-router#readme",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
