# Rust Copy Engine Configuration
# Copy to .env and fill in your values

# RPC Configuration
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=

# WebSocket (Helius recommended for production)
WS_URL=wss://mainnet.helius-rpc.com/?api-key=

# Jito Configuration (for MEV bundling)
JITO_ENABLED=true

# API Security
RUST_API_KEY=change_me_in_production

# Wallet Configuration (base58 encoded private key)
# WARNING: Never commit this file with real keys!
SOLANA_PRIVATE_KEY=

# Logging
RUST_LOG=info
