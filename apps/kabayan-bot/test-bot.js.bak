const TelegramBot = require('node-telegram-bot-api');

const token = '8735850138:AAG_6G-hR0MMKYGx6N4wIZAknzyMz232U64';

// Test dengan polling
const bot = new TelegramBot(token, { polling: true });

console.log('✅ Bot started, waiting for messages...');

bot.on('text', (msg) => {
  console.log('Received message from', msg.from?.first_name, ':', msg.text);
  
  // Reply
  bot.sendMessage(msg.chat.id, 'Hello! Bot is working! 👋');
});

bot.on('polling_error', (error) => {
  console.log('Polling error:', error.message);
});
